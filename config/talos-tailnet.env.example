# Copy to .env and set TS_AUTHKEY before running scripts.
# The auth key should be reusable or ephemeral and allowed to create the node
# hostnames below. Never commit .env.

TS_AUTHKEY=tskey-auth-REPLACE_ME

CLUSTER_NAME=talos-tailnet-local
TALOS_VERSION=v1.11.5
KUBERNETES_VERSION=1.34.1
# Primary cluster CNI. Use cilium for the default policy/flow-visibility path,
# or set flannel to fall back to the older Talos-managed CNI during rollback.
CLUSTER_CNI=cilium
# Pinned Cilium chart/app version used for the Talos bootstrap manifest render.
CILIUM_VERSION=1.19.3
TAILSCALE_CIDR=100.64.0.0/10
# Keep this false when using Talos ResolverConfig for host DNS. Talos nodes do
# not let the Tailscale extension rewrite /etc/resolv.conf.
TAILSCALE_ACCEPT_DNS=false
TAILSCALE_DNS_RESOLVERS="100.100.100.100 9.9.9.9 1.1.1.1 8.8.8.8"
# Set this to your tailnet search suffix if you want Talos host DNS to expand
# short node names like talos-ts-cp1 via MagicDNS.
TAILSCALE_SEARCH_DOMAIN=
# Optional node suffix handling. Leave empty for stable names, set a literal
# suffix like dev1, or use random to generate a fresh suffix per from-scratch
# cluster rebuild.
NODE_NAME_SUFFIX=

CONTROL_PLANE_NODE_NAMES="talos-ts-cp1 talos-ts-cp2 talos-ts-cp3"
WORKER_NODE_NAMES="talos-ts-worker1 talos-ts-worker2 talos-ts-worker3"
CONTROL_PLANE_ENDPOINT=https://talos-ts-cp1:6443

VM_MEMORY_MIB=4096
VM_CPUS=2
VM_CPU_MODEL=max
VM_DISK_GIB=20
WORKER_DATA_DISK_GIB=20
INSTALL_DISK=/dev/vda

# Host ports are only for first-boot talosctl access before the nodes are
# reachable over Tailscale. Each VM has isolated QEMU user-mode networking.
HOST_API_BASE_PORT=50001
HOST_K8S_BASE_PORT=64431

# QEMU display backend. Use "vnc" for headless-friendly localhost VNC, or "gtk"
# for local QEMU windows with zoom-to-fit.
VM_DISPLAY_BACKEND=vnc

# QEMU VNC display numbers. Display :1 is localhost TCP port 5901.
HOST_VNC_BASE_DISPLAY=1

# QEMU VGA output. Keep this simple: Talos' boot console is most readable when
# the guest exposes a small VGA surface and the VNC viewer scales it up.
VM_DISPLAY_DEVICE=VGA
VM_DISPLAY_WIDTH=
VM_DISPLAY_HEIGHT=

# Argo CD bootstrap settings. The root Application points at this repository
# path; set ARGOCD_REPO_URL to a remote URL reachable from inside the cluster.
ARGOCD_VERSION=v3.3.6
ARGOCD_NAMESPACE=argocd
ARGOCD_REPO_URL=https://github.com/REPLACE_ME/talos-tailscale.git
ARGOCD_TARGET_REVISION=main
ARGOCD_ROOT_PATH=gitops/clusters/talos-tailnet-local/root
LONGHORN_NAMESPACE=longhorn-system
LONGHORN_APP_NAME=longhorn

# Optional Sealed Secrets key backup location. Keep this outside git if you use
# make clean frequently; make argocd restores it before the controller syncs.
# SEALED_SECRETS_BACKUP_FILE=/secure/offline/location/talos-tailnet-local-sealed-secrets-key.yaml

# Longhorn-on-Talos preparation defaults. Worker VMs get a second virtio disk
# by default, and the selector below targets that dedicated data disk.
LONGHORN_VOLUME_NAME=longhorn
LONGHORN_DISK_SELECTOR='disk.dev_path == "/dev/vdb"'
LONGHORN_VOLUME_MAX_SIZE=16GiB
