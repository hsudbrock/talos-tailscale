# Copy to .env before running scripts. `TS_AUTHKEY` is only used for the hosted
# Tailscale fallback (`HEADSCALE_BOOTSTRAP_MODE=disabled`). Never commit .env.

TS_AUTHKEY=tskey-auth-REPLACE_ME

CLUSTER_NAME=talos-tailnet-local
TALOS_VERSION=v1.12.5
KUBERNETES_VERSION=1.34.1
# Primary cluster CNI. Use cilium for the default policy/flow-visibility path,
# or set flannel to fall back to the older Talos-managed CNI during rollback.
CLUSTER_CNI=cilium
# Pinned Cilium chart/app version used for the Talos bootstrap manifest render.
CILIUM_VERSION=1.19.3
TAILSCALE_CIDR=100.64.0.0/10
# Keep this false when using Talos ResolverConfig for host DNS. Talos nodes do
# not let the Tailscale extension rewrite /etc/resolv.conf.
TAILSCALE_ACCEPT_DNS=false
TAILSCALE_DNS_RESOLVERS="100.100.100.100 9.9.9.9 1.1.1.1 8.8.8.8"
# Set this to your tailnet search suffix if you want Talos host DNS to expand
# short node names like talos-ts-cp1 via MagicDNS.
TAILSCALE_SEARCH_DOMAIN=
# Optional node suffix handling. Leave empty for stable names, set a literal
# suffix like dev1, or use random to generate a fresh suffix per from-scratch
# cluster rebuild.
NODE_NAME_SUFFIX=random

CONTROL_PLANE_NODE_NAMES="talos-ts-cp1 talos-ts-cp2 talos-ts-cp3"
WORKER_NODE_NAMES="talos-ts-worker1"
CONTROL_PLANE_ENDPOINT=https://talos-ts-cp1:6443

VM_MEMORY_MIB=4096
VM_CPUS=2
VM_CPU_MODEL=max
VM_DISK_GIB=20
WORKER_DATA_DISK_GIB=20
INSTALL_DISK=/dev/vda

# Host ports are only for first-boot talosctl access before the nodes are
# reachable over Tailscale. Each VM has isolated QEMU user-mode networking.
HOST_API_BASE_PORT=50001
HOST_K8S_BASE_PORT=64431

# QEMU display backend. Use "vnc" for headless-friendly localhost VNC, or "gtk"
# for local QEMU windows with zoom-to-fit.
VM_DISPLAY_BACKEND=gtk

# QEMU VNC display numbers. Display :1 is localhost TCP port 5901.
HOST_VNC_BASE_DISPLAY=1

# QEMU VGA output. Keep this simple: Talos' boot console is most readable when
# the guest exposes a small VGA surface and the VNC viewer scales it up.
VM_DISPLAY_DEVICE=VGA
VM_DISPLAY_WIDTH=
VM_DISPLAY_HEIGHT=

# Argo CD bootstrap settings. The root Application points at this repository
# path; set ARGOCD_REPO_URL to a remote URL reachable from inside the cluster.
ARGOCD_VERSION=v3.3.6
ARGOCD_NAMESPACE=argocd
ARGOCD_REPO_URL=https://github.com/REPLACE_ME/talos-tailscale.git
ARGOCD_TARGET_REVISION=main
ARGOCD_ROOT_PATH=gitops/clusters/talos-tailnet-local/root
LONGHORN_NAMESPACE=longhorn-system
LONGHORN_APP_NAME=longhorn

# Optional Sealed Secrets key backup location. Keep this outside git if you use
# make clean frequently; make argocd restores it before the controller syncs.
# SEALED_SECRETS_BACKUP_FILE=/secure/offline/location/talos-tailnet-local-sealed-secrets-key.yaml

# Longhorn-on-Talos preparation defaults. Worker VMs get a second virtio disk
# by default, and the selector below targets that dedicated data disk.
LONGHORN_VOLUME_NAME=longhorn
LONGHORN_DISK_SELECTOR='disk.dev_path == "/dev/vdb"'
LONGHORN_VOLUME_MAX_SIZE=8GiB

# Headscale bootstrap mode:
# - disabled: current hosted control plane only
# - local-vm: start a local Headscale support VM and expose it through host forwards
# - external: do not start a local VM; point HEADSCALE_URL at a remote Headscale service
HEADSCALE_BOOTSTRAP_MODE=disabled

# First-class Headscale client endpoint. For local-vm mode the default is
# http://10.0.2.2:${HEADSCALE_HOST_HTTP_PORT} so Talos guests can reach the host
# forwarded port through QEMU slirp. Override this to test the same logical
# endpoint shape you expect to use later in Hetzner, AWS, Azure, or elsewhere.
# HEADSCALE_URL=https://headscale.example.com
#
# Talos-node enrollment auth in Headscale mode:
# - set HEADSCALE_AUTH_KEY explicitly for external mode or to override the
#   local-vm default
# - in local-vm mode, if HEADSCALE_AUTH_KEY is empty, the repo creates a
#   reusable key and stores it in .state/headscale/talos-authkey
# HEADSCALE_AUTH_KEY=
# Optional: set HEADSCALE_HOST_AUTH_KEY explicitly for host enrollment instead
# of auto-generating one in local-vm mode.
# HEADSCALE_HOST_AUTH_KEY=
HEADSCALE_TALOS_USER=headscale-talos
HEADSCALE_TALOS_TAG=tag:talos-lab
HEADSCALE_TALOS_KEY_EXPIRATION=720h
HEADSCALE_HOST_CONNECT_URL=http://127.0.0.1:18080
HEADSCALE_HOST_USER=headscale-host
HEADSCALE_HOST_TAG=
HEADSCALE_HOST_KEY_EXPIRATION=720h
HEADSCALE_HOST_ACCEPT_DNS=true

# Local-vm mode manages a separate support VM, not a Talos node. Point
# HEADSCALE_VM_IMAGE at a prepared writable qcow2 image or a read-only base qcow2
# image that the repo can use to create a persistent overlay at HEADSCALE_VM_DISK.
# Recommended preparation path: Debian 12 or Ubuntu LTS guest with the official
# Headscale package installed and configured under systemd.
HEADSCALE_VM_NAME=headscale
HEADSCALE_VM_IMAGE=
# HEADSCALE_VM_DISK=/absolute/path/to/headscale.qcow2
HEADSCALE_VM_MEMORY_MIB=2048
HEADSCALE_VM_CPUS=2
HEADSCALE_VM_DISPLAY_BACKEND=none
HEADSCALE_HOST_VNC_DISPLAY=7
HEADSCALE_VM_DISPLAY_DEVICE=VGA
HEADSCALE_VM_DISPLAY_WIDTH=
HEADSCALE_VM_DISPLAY_HEIGHT=
HEADSCALE_HOST_HTTP_PORT=18080
HEADSCALE_GUEST_HTTP_PORT=8080
HEADSCALE_HOST_SSH_PORT=10022
HEADSCALE_GUEST_SSH_PORT=22

# Headscale base image build inputs. `make headscale-image` uses Packer's QEMU
# builder plus cloud-init to turn an official Debian 12 cloud qcow2 image into
# a reusable Headscale base image. This is shaped so the same image pipeline can
# later be adapted for Hetzner-oriented builds instead of staying local-only.
HEADSCALE_VERSION=0.28.0
HEADSCALE_ARCH=amd64
HEADSCALE_BASE_IMAGE_URL=https://cloud.debian.org/images/cloud/bookworm/latest/debian-12-genericcloud-amd64.qcow2
# HEADSCALE_IMAGE_OUTPUT=/absolute/path/to/headscale-base.qcow2
HEADSCALE_PACKER_SSH_USERNAME=packer
HEADSCALE_IMAGE_HOSTNAME=headscale-image
HEADSCALE_IMAGE_INSTANCE_ID=headscale-image
HEADSCALE_VALIDATE_CLIENT_NAMES="headscale-test-client1 headscale-test-client2"
HEADSCALE_VALIDATE_URL=http://127.0.0.1:18080
HEADSCALE_VALIDATE_USER=headscale-test
HEADSCALE_VALIDATE_TAG=tag:talos-lab
HEADSCALE_VALIDATE_KEY_EXPIRATION=24h
HEADSCALE_SERVER_URL=http://headscale.example.internal:8080
HEADSCALE_LISTEN_ADDR=0.0.0.0:8080
HEADSCALE_METRICS_LISTEN_ADDR=127.0.0.1:9090
HEADSCALE_GRPC_LISTEN_ADDR=127.0.0.1:50443
HEADSCALE_PREFIX_V4=100.64.0.0/10
HEADSCALE_PREFIX_V6=fd7a:115c:a1e0::/48
HEADSCALE_BASE_DOMAIN=tailnet.home.arpa
HEADSCALE_GLOBAL_DNS_RESOLVERS="1.1.1.1 8.8.8.8 9.9.9.9"
